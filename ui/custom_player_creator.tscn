[gd_scene load_steps=2 format=3 uid="uid://cpc_modal_scene"]

[ext_resource type="Script" path="res://ui/custom_player_creator.gd" id="1_cpc_script"]

[node name="CustomPlayerCreator" type="PanelContainer"]
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -300.0
offset_top = -300.0
offset_right = 300.0
offset_bottom = 300.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_cpc_script")

[node name="VBox" type="VBoxContainer" parent="."]
layout_mode = 2
theme_override_constants/separation = 15

[node name="Header" type="Label" parent="VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.3, 0.9, 0.3, 1)
theme_override_font_sizes/font_size = 28
text = "CUSTOM PLAYER CREATOR"
horizontal_alignment = 1

[node name="HSeparator" type="HSeparator" parent="VBox"]
layout_mode = 2

[node name="HBox_Names" type="HBoxContainer" parent="VBox"]
layout_mode = 2
theme_override_constants/separation = 20
alignment = 1

[node name="VBox_First" type="VBoxContainer" parent="VBox/HBox_Names"]
layout_mode = 2
size_flags_horizontal = 3

[node name="Label" type="Label" parent="VBox/HBox_Names/VBox_First"]
layout_mode = 2
text = "FIRST NAME"
horizontal_alignment = 1

[node name="InputFirstName" type="LineEdit" parent="VBox/HBox_Names/VBox_First"]
layout_mode = 2
placeholder_text = "e.g. John"
alignment = 1
max_length = 15

[node name="VBox_Last" type="VBoxContainer" parent="VBox/HBox_Names"]
layout_mode = 2
size_flags_horizontal = 3

[node name="Label" type="Label" parent="VBox/HBox_Names/VBox_Last"]
layout_mode = 2
text = "LAST NAME"
horizontal_alignment = 1

[node name="InputLastName" type="LineEdit" parent="VBox/HBox_Names/VBox_Last"]
layout_mode = 2
placeholder_text = "e.g. Doe"
alignment = 1
max_length = 15

[node name="VBox_Num" type="VBoxContainer" parent="VBox/HBox_Names"]
layout_mode = 2

[node name="Label" type="Label" parent="VBox/HBox_Names/VBox_Num"]
layout_mode = 2
text = "NUMBER"
horizontal_alignment = 1

[node name="InputNumber" type="SpinBox" parent="VBox/HBox_Names/VBox_Num"]
layout_mode = 2
max_value = 99.0
value = 99.0
alignment = 1

[node name="HSeparator2" type="HSeparator" parent="VBox"]
layout_mode = 2

[node name="HBox_StatsTitle" type="HBoxContainer" parent="VBox"]
layout_mode = 2
alignment = 1

[node name="LabelStats" type="Label" parent="VBox/HBox_StatsTitle"]
